# Фрагмент для nginx: TLS выдаётся certbot (пути к сертификатам подставятся сами).
# Замените YOUR_DOMAIN.example и путь к unix-сокету Gunicorn.

upstream xseo_django {
    server unix:/run/gunicorn/xseo.sock fail_timeout=0;
}

server {
    server_name YOUR_DOMAIN.example;
    client_max_body_size 20M;

    location / {
        proxy_pass http://xseo_django;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_redirect off;
    }

    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/YOUR_DOMAIN.example/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/YOUR_DOMAIN.example/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

server {
    if ($host = YOUR_DOMAIN.example) {
        return 301 https://$host$request_uri;
    }
    listen 80;
    server_name YOUR_DOMAIN.example;
    return 404;
}
