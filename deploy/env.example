# Скопируйте в /etc/xseo/environment (или другой путь) и заполните.
# В unit-файлах указан EnvironmentFile=/etc/xseo/environment — поменяйте путь при необходимости.

# Общий токен бота (одинаковый у процесса бота и у Gunicorn/Django для проверки Web App).
TELEGRAM_BOT_TOKEN=000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Версия политики (сохраняется в БД при согласии; по умолчанию в коде 1.0).
POLICY_VERSION=1.0

# --- только бот (xseo-bot.service) ---
# Полный HTTPS URL до API списка доступа (обязательно https для кнопки Web App согласия).
BOT_ALLOWED_LIST_URL=https://YOUR_DOMAIN.example/api/allowed-ids/

# --- только Django (xseo-django-gunicorn.service) ---
# Сгенерируйте: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-random-string

# Продакшен Django (иначе ALLOWED_HOSTS останется localhost при DEBUG=false).
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=YOUR_DOMAIN.example
