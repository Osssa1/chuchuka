# Скопируйте в /opt/xseo_ip_bot/deploy/production.env (или другой путь) и подставьте значения.
# Права: chmod 600 production.env
#
# Один и тот же файл можно подключить в systemd и для Django, и для бота (см. *.service).

# Общий токен бота (обязателен и у бота, и у Django для проверки Web App initData).
TELEGRAM_BOT_TOKEN=000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Версия политики (опционально; должна совпадать с тем, что ожидает бот, если вы её меняли).
POLICY_VERSION=1.0

# Только для процесса бота (в unit бота через EnvironmentFile):
# Полный HTTPS URL до API списка доступа (обязательно https:// и путь .../api/allowed-ids/).
BOT_ALLOWED_LIST_URL=https://YOUR_DOMAIN.example/api/allowed-ids/

# Опционально для Django (если не задаёте в settings): секрет ключа
# DJANGO_SECRET_KEY=...
